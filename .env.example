# Copy to `.env` in this folder. Create a project at https://supabase.com → Settings → API.
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-public-key

# Optional: timer runs at real time by default. Uncomment and set to e.g. 180 for faster local testing.
# REACT_APP_TIMER_SPEED_MULTIPLIER=180
